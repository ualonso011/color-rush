<?xml version="1.0" encoding="utf-8"?>
<!--
  Background drawable for the ColorRush adaptive launcher icon.
  Dark gradient background with subtle radial glow for arcade aesthetic.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base dark background -->
    <path
        android:fillColor="#0A0E27"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />
    
    <!-- Subtle radial glow in center -->
    <path
        android:fillColor="#0D1117"
        android:pathData="M54,54 m-40,0 a40,40 0 1,0 80,0 a40,40 0 1,0 -80,0" />
    
    <!-- Inner darker circle for depth -->
    <path
        android:fillColor="#0A0E27"
        android:pathData="M54,54 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0" />
</vector>
